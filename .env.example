# Supabase connection (required)
# Values from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# GitHub Pages base URL – set to match your repository name
# Production: /davplanspiel/
# Local dev:  / (default, leave commented out)
# VITE_BASE_URL=/davplanspiel/

# hCaptcha (https://dashboard.hcaptcha.com)
# Set VITE_CAPTCHA_ENABLED=false to skip CAPTCHA during local development
VITE_CAPTCHA_ENABLED=true
VITE_HCAPTCHA_SITEKEY=your-hcaptcha-site-key

# Database init – never commit these
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_PAT=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SUPABASE_SECRET=sb_secret_...
# HCAPTCHA_SECRET=ES_...
